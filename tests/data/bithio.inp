@jobs
task: trajectory
@end

@method settings
basis: sto-3g
@end

@trajectory
description: bithiophene in water
topology file: bithio.tpr
trajectory file: bithio.xtc
sampling time: 300 - 400 (100)
quantum region: resname RES
classical polarizable region: 3.0
classical non-polarizable region: 4.5
units: ps, angstrom
@end

@spectrum settings
line profile: gaussian
broadening parameter: 0.4
units: eV
@end

@response
nstates: 2
@end

@molecule
charge: 0
multiplicity: 1
@end 

@charges
O  -0.67444  water
H   0.33722  water
H   0.33722  water
O  -0.834    water-n
H   0.417    water-n
H   0.417    water-n
@end

@polarizabilities
O       5.73935    0.00000    0.00000    5.73935    0.00000    5.73935  water
H       2.30839    0.00000    0.00000    2.30839    0.00000    2.30839  water
H       2.30839    0.00000    0.00000    2.30839    0.00000    2.30839  water
@end
